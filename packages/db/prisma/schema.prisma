generator client {
  provider = "prisma-client-js"
}

// PostgreSQL — use Neon/Render locally (see docker-compose.yml) or SQLite file for legacy dev
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  member
  manager
  super_admin
}

enum SubscriptionTier {
  basic
  standard
  premium
}

enum SubscriptionStatus {
  active
  suspended
  cancelled
}

enum ContentType {
  advert
  education
  information
}

model User {
  id                 String             @id @default(cuid())
  email              String             @unique
  name               String
  passwordHash       String?
  role               UserRole           @default(member)
  subscriptionTier   SubscriptionTier   @default(basic)
  subscriptionStatus SubscriptionStatus @default(active)
  stripeCustomerId     String?
  stripeSubscriptionId String?
  farms              Farm[]
  posts              ContentPost[]
  createdAt          DateTime           @default(now())
}

model ContentPost {
  id        String      @id @default(cuid())
  type      ContentType
  title     String
  body      String
  mediaUrl  String?
  authorId  String
  author    User        @relation(fields: [authorId], references: [id])
  published Boolean     @default(true)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
}

model Farm {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  name      String
  location  String
  city      String
  state     String
  country   String
  ponds     Pond[]
  createdAt DateTime @default(now())
}

model Pond {
  id       String       @id @default(cuid())
  farmId   String
  farm     Farm         @relation(fields: [farmId], references: [id])
  name     String
  number   Int
  lengthM  Float
  widthM   Float
  depthM   Float
  cycles   StockCycle[]
  createdAt DateTime    @default(now())
}

model StockCycle {
  id                   String              @id @default(cuid())
  pondId               String
  pond                 Pond                @relation(fields: [pondId], references: [id])
  quantityStocked      Int
  averageWeightAtStockingG Float
  fingerlingPrice      Float
  stockingDate         DateTime
  desiredCrudeProteinPct Float
  desiredFeedQuantityKg  Float
  mortalityLogs        DailyMortalityLog[]
  feedLogs             DailyFeedLog[]
  waterLogs            WaterParameterLog[]
  createdAt            DateTime            @default(now())
}

model DailyMortalityLog {
  id           String     @id @default(cuid())
  stockCycleId String
  stockCycle   StockCycle @relation(fields: [stockCycleId], references: [id])
  date         DateTime
  count        Int
  createdAt    DateTime   @default(now())

  @@unique([stockCycleId, date])
}

model DailyFeedLog {
  id           String     @id @default(cuid())
  stockCycleId String
  stockCycle   StockCycle @relation(fields: [stockCycleId], references: [id])
  date         DateTime
  actualKg     Float
  createdAt    DateTime   @default(now())

  @@unique([stockCycleId, date])
}

model WaterParameterLog {
  id                String     @id @default(cuid())
  stockCycleId      String
  stockCycle        StockCycle @relation(fields: [stockCycleId], references: [id])
  date              DateTime
  ph                Float?
  dissolvedOxygenMgL Float?
  temperatureC      Float?
  ammoniaMgL        Float?
  notes             String?
  createdAt         DateTime   @default(now())

  @@unique([stockCycleId, date])
}
